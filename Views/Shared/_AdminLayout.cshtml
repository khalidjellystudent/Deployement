@* Views/Shared/AdminLayout.cshtml *@
@using TicketSystem.Data
@inject AppDbContext _db
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] – لوحة تحكم المسؤول</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .admin-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .admin-logo-image {
            width: 92px;
            height: 92px;
            object-fit: contain;
            display: block;
        }

        .sidebar {
            transition: all 0.3s;
        }

        .nav-link {
            transition: all 0.2s;
        }

            .nav-link:hover {
                background-color: rgba(59, 130, 246, 0.1);
            }

            .nav-link.active {
                background-color: #3b82f6;
                color: white;
            }

        /* Mobile: Hide sidebar by default */
        @@media (max-width: 768px) {
            .sidebar {
                width: 86vw;
                max-width: 320px;
                top: 0;
                bottom: 0;
                transform: translateX(100%);
                border-top-right-radius: 0;
                border-bottom-right-radius: 0;
            }

            .sidebar.active {
                transform: translateX(0);
            }

            .overlay {
                display: none;
                position: fixed;
                inset: 0;
                background-color: rgba(0, 0, 0, 0.5);
                z-index: 10;
            }

            .overlay.active {
                display: block;
            }

            .mobile-menu-toggle {
                display: inline-flex;
            }

            .main-content {
                margin-right: 0 !important;
            }

            .admin-page-shell {
                padding-top: 4.5rem;
            }

            .admin-main {
                padding: 1rem !important;
            }

            .admin-footer {
                padding-inline: 1rem !important;
                padding-block: 1rem !important;
            }

            .admin-logo-image {
                width: 76px;
                height: 76px;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-gray-50 font-sans">
    @{
        var unreadCount = 0;
        try {
            unreadCount = _db.Feedbacks.Count(f => !f.IsRead);
        } catch {
            unreadCount = 0;
        }
    }

    <button id="menuBtn" onclick="toggleSidebar()" class="mobile-menu-toggle md:hidden fixed top-4 right-4 z-30 inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-600 text-white shadow-lg">
        <i class="fas fa-bars text-lg"></i>
        <span class="sr-only">فتح القائمة</span>
    </button>

    <div class="flex h-screen overflow-hidden relative">
        <!-- Mobile Overlay -->
        <div id="overlay" class="overlay" onclick="toggleSidebar()"></div>

    <!-- Sidebar (off-canvas on small screens, visible on md+) -->
    <div id="sidebar" class="sidebar bg-white w-64 h-full fixed shadow-lg z-20 right-0 transform transition-transform duration-300 md:translate-x-0 translate-x-full">
            <!-- Logo -->
            <div class="p-4 border-b border-gray-200">
                <div class="admin-logo">
                    <img src="~/images/logo.png" alt="شعار النظام" class="admin-logo-image" />
                    <h1 class="text-xl font-bold text-blue-600">النظام الإداري</h1>
                </div>
            </div>

            <!-- User Profile -->
            <div class="p-4 border-b border-gray-200 flex items-center space-x-3 space-x-reverse">
                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center">
                    <i class="fas fa-user text-blue-600"></i>
                </div>
                <div>
                    <p class="font-medium text-gray-800">@User.Identity?.Name</p>
                    <span class="text-xs text-gray-500">مدير النظام</span>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="p-2">
                <ul class="space-y-1">
                    <li>
                        <a asp-controller="Admin" asp-action="Index" class="nav-link flex items-center p-3 rounded-lg text-gray-700 hover:text-blue-600">
                            <i class="fas fa-tachometer-alt ml-3"></i>
                            <span>لوحة التحكم</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin" asp-action="UserList" class="nav-link flex items-center p-3 rounded-lg text-gray-700 hover:text-blue-600">
                            <i class="fas fa-users ml-3"></i>
                            <span>إدارة المستخدمين</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin" asp-action="FeedbackList" class="nav-link flex items-center p-3 rounded-lg text-gray-700 hover:text-blue-600">
                            <i class="fas fa-comment-alt ml-3"></i>
                            <span>الرسائل والملاحظات</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin" asp-action="ViolationList" class="nav-link flex items-center p-3 rounded-lg text-gray-700 hover:text-blue-600">
                            <i class="fas fa-exclamation-triangle ml-3"></i>
                            <span>إدارة المخالفات</span>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="nav-link flex items-center p-3 rounded-lg text-gray-700 hover:text-blue-600">
                            <i class="fas fa-chart-bar ml-3"></i>
                            <span>التقارير والإحصائيات</span>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="nav-link flex items-center p-3 rounded-lg text-gray-700 hover:text-blue-600">
                            <i class="fas fa-cog ml-3"></i>
                            <span>الإعدادات</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>

        <!-- Main Content -->
        <div id="mainContent" class="main-content admin-page-shell flex-1 flex flex-col overflow-hidden mr-0 md:mr-64 transition-all duration-300 ease-in-out">

            <!-- Page Content -->
            <main class="admin-main flex-1 overflow-y-auto p-6 bg-gray-50">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="admin-footer bg-white border-t py-4 px-6">
                <div class="flex flex-col md:flex-row justify-between items-center text-center md:text-right">
                    <div class="text-sm text-gray-500 mb-2 md:mb-0">
                        نظام المخالفات المرورية © @DateTime.Now.Year - جميع الحقوق محفوظة
                    </div>
                    <div class="flex space-x-4 space-x-reverse text-sm">
                        <a href="#" class="text-gray-500 hover:text-blue-600">الشروط والأحكام</a>
                        <a href="#" class="text-gray-500 hover:text-blue-600">سياسة الخصوصية</a>
                        <a href="#" class="text-gray-500 hover:text-blue-600">الدعم الفني</a>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');
            sidebar.classList.toggle('active');
            overlay.classList.toggle('active');
        }

        // Close sidebar when clicking on a link on mobile
        document.addEventListener('DOMContentLoaded', function() {
            const navLinks = document.querySelectorAll('.nav-link');
            navLinks.forEach(link => {
                link.addEventListener('click', function() {
                    if (window.innerWidth < 768) {
                        toggleSidebar();
                    }
                });
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>