<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - نظام المخالفات المرورية</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <environment include="Development">
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
              asp-fallback-href="~/lib/bootstrap/dist/css/bootstrap.min.css"
              asp-fallback-test-class="sr-only" asp-fallback-test-property="position" asp-fallback-test-value="absolute" />
    </environment>

    <style>
        :root {
            --office-bg: #f8fafc;
            --office-primary: #1d4ed8;
            --office-text: #0f172a;
            --office-white: #ffffff;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--office-bg);
            color: var(--office-text);
            font-family: 'Tajawal', sans-serif;
        }

        .office-header {
            background: var(--office-white);
            border-bottom: 1px solid rgba(15, 23, 42, 0.08);
            position: sticky;
            top: 0;
            z-index: 20;
        }

        .office-header-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0.85rem 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .office-brand {
            color: var(--office-text);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
            font-weight: 800;
            font-size: 1.08rem;
        }

        .office-brand-image {
            width: 5.3rem;
            height: 5.3rem;
            object-fit: contain;
            display: block;
        }

        .office-brand-icon {
            width: 2.1rem;
            height: 2.1rem;
            border-radius: 0.65rem;
            background: var(--office-primary);
            color: var(--office-white);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

        .office-menu-btn {
            display: none;
            border: 1px solid rgba(29, 78, 216, 0.25);
            color: var(--office-primary);
            background: var(--office-white);
            border-radius: 0.55rem;
            width: 2.4rem;
            height: 2.4rem;
            align-items: center;
            justify-content: center;
        }

        .office-nav {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .office-nav-link,
        .office-logout-btn {
            text-decoration: none;
            border: 0;
            background: transparent;
            color: var(--office-text);
            padding: 0.5rem 0.85rem;
            border-radius: 0.65rem;
            font-weight: 600;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .office-nav-link:hover,
        .office-logout-btn:hover {
            background: rgba(29, 78, 216, 0.08);
            color: var(--office-primary);
        }

        .office-nav-link.active {
            background: var(--office-primary);
            color: var(--office-white);
        }

        .office-main {
            max-width: 1200px;
            margin: 1.25rem auto;
            padding: 0 1rem;
            min-height: calc(100vh - 170px);
        }

        .office-footer {
            background: var(--office-white);
            border-top: 1px solid rgba(15, 23, 42, 0.08);
            color: var(--office-text);
            text-align: center;
            padding: 1rem;
            font-size: 0.92rem;
        }

        @@media (max-width: 992px) {
            .office-brand-image {
                width: 4.7rem;
                height: 4.7rem;
            }

            .office-menu-btn {
                display: inline-flex;
            }

            .office-nav {
                position: absolute;
                top: 100%;
                right: 0;
                left: 0;
                background: var(--office-white);
                border-top: 1px solid rgba(15, 23, 42, 0.08);
                display: none;
                flex-direction: column;
                align-items: stretch;
                gap: 0;
                padding: 0.45rem;
            }

            .office-nav.open {
                display: flex;
            }

            .office-nav-link,
            .office-logout-btn {
                width: 100%;
                justify-content: flex-start;
                padding: 0.7rem 0.8rem;
            }

            .office-header-inner {
                position: relative;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="office-header">
        <div class="office-header-inner">
            <a asp-controller="Office" asp-action="Index" class="office-brand">
                <img src="~/images/logo.png" alt="شعار النظام" class="office-brand-image" />
                <span>مكتب المخالفات</span>
            </a>

            <button type="button" id="officeMenuBtn" class="office-menu-btn" aria-label="فتح القائمة" aria-expanded="false" aria-controls="officeNav">
                <i class="fas fa-bars"></i>
            </button>

            <nav id="officeNav" class="office-nav" aria-label="قائمة المكتب">
                <a asp-controller="Office" asp-action="Index" class="office-nav-link" data-office-nav="/Office/Index">
                    <i class="fas fa-house"></i>
                    لوحة التحكم
                </a>
                <a asp-controller="Office" asp-action="Register" class="office-nav-link" data-office-nav="/Office/Register">
                    <i class="fas fa-user-plus"></i>
                    تسجيل المستخدمين
                </a>
                <a asp-controller="Office" asp-action="ScanPlate" class="office-nav-link" data-office-nav="/Office/ScanPlate">
                    <i class="fas fa-id-card"></i>
                    مسح اللوحات
                </a>
                <a asp-controller="Office" asp-action="Reports" class="office-nav-link" data-office-nav="/Office/Reports">
                    <i class="fas fa-chart-simple"></i>
                    التقارير
                </a>
                <a asp-controller="Office" asp-action="Process" class="office-nav-link" data-office-nav="/Office/Process">
                    <i class="fas fa-clipboard-check"></i>
                    معالجة التذاكر
                </a>
                <form asp-controller="Home" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="office-logout-btn">
                        <i class="fas fa-right-from-bracket"></i>
                        تسجيل الخروج
                    </button>
                </form>
            </nav>
        </div>
    </header>

    <main class="office-main">
        @RenderBody()
    </main>

    <footer class="office-footer">
        © @DateTime.Now.Year - نظام المخالفات المرورية
    </footer>

    <environment include="Development">
        <script src="~/lib/jquery/dist/jquery.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"
                asp-fallback-src="~/lib/jquery/dist/jquery.min.js"
                asp-fallback-test="window.jQuery">
        </script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
                asp-fallback-src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"
                asp-fallback-test="window.jQuery && window.jQuery.fn && window.jQuery.fn.modal">
        </script>
    </environment>

    @RenderSection("Scripts", required: false)

    <script>
        (function () {
            const menuBtn = document.getElementById("officeMenuBtn");
            const nav = document.getElementById("officeNav");

            if (menuBtn && nav) {
                menuBtn.addEventListener("click", function () {
                    const isOpen = nav.classList.toggle("open");
                    menuBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
                });
            }

            const currentPath = (window.location.pathname || "").toLowerCase();
            document.querySelectorAll(".office-nav-link").forEach(function (link) {
                const route = (link.getAttribute("data-office-nav") || "").toLowerCase();
                if (route && currentPath.startsWith(route)) {
                    link.classList.add("active");
                }
            });
        })();
    </script>
</body>
</html>