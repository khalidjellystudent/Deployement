<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] ?? "لوحة الضابط") - نظام إدارة المخالفات المرورية</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
              asp-fallback-href="~/lib/bootstrap/dist/css/bootstrap.min.css"
              asp-fallback-test-class="sr-only" asp-fallback-test-property="position" asp-fallback-test-value="absolute" />
    </environment>

    <link rel="stylesheet" href="~/css/officer-layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-color: #1d4ed8;
            --primary-dark: #1e40af;
            --accent-color: #0ea5e9;
            --success-color: #10b981;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --light-bg: #f6f8fc;
            --card-bg: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #64748b;
        }

        body {
            margin: 0;
            width: 100%;
            padding: 0;
            background-color: var(--light-bg);
            color: var(--text-primary);
            line-height: 1.6;
            font-family: 'Tajawal', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Header Styles */
        header {
            background: rgba(255, 255, 255, 0.96);
            color: var(--text-primary);
            padding: 12px 0;
            border-bottom: 1px solid #e5e7eb;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
            position: sticky;
            top: 0;
            backdrop-filter: blur(12px);
            z-index: 1000;
        }

        .header-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-image {
            width: 92px;
            height: 92px;
            object-fit: contain;
            display: block;
        }

        .logo-text {
            font-size: 20px;
            font-weight: 700;
        }

        nav {
            display: flex;
            gap: 20px;
            align-items: center;
        }

            nav a {
                color: var(--text-primary);
                text-decoration: none;
                padding: 10px 14px;
                border-radius: 999px;
                border: 1px solid transparent;
                transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
            }

                nav a:hover, nav a.active {
                    background: #eff6ff;
                    color: var(--primary-color);
                    border-color: #dbeafe;
                }

                nav a.active {
                    font-weight: 600;
                }

        /* Main Content (avoid overriding Bootstrap's .container) */
        .officer-container {
            max-width: 1200px;
            margin: 24px auto;
            padding: 0 16px;
            flex: 1;
        }

        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .card {
            background: var(--card-bg);
            border-radius: 18px;
            padding: 0;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
            transition: all 0.3s ease;
            text-align: right;
            border: 1px solid #e2e8f0;
            height: 100%;
        }

            .card:hover {
                transform: translateY(-2px);
                box-shadow: 0 14px 28px rgba(15, 23, 42, 0.08);
                border-color: #cbd5e1;
            }

        .card-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 0;
            color: var(--primary-color);
            justify-content: flex-end;
        }

            .card-header i {
                font-size: 24px;
            }

            .card-header h2 {
                font-size: 20px;
            }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.625rem 1.1rem;
            border-radius: 10px;
            text-decoration: none;
            transition: all 0.2s ease;
            border: 1px solid transparent;
            cursor: pointer;
            float: none;
            font-weight: 500;
            gap: 0.5rem;
            box-shadow: 0 1px 2px 0 rgba(15, 23, 42, 0.04);
        }

            .btn:hover {
                background: var(--primary-dark);
                color: white;
                transform: translateY(-1px);
                box-shadow: 0 6px 12px rgba(15, 23, 42, 0.08);
            }

            .btn i {
                font-size: 1rem;
            }

        /* Footer */
        footer {
            background: #0f172a;
            color: white;
            padding: 1.25rem 16px;
            text-align: center;
            margin-top: auto;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

            footer a {
                color: rgba(255, 255, 255, 0.8);
                text-decoration: none;
                transition: color 0.2s ease;
            }

                footer a:hover {
                    color: white;
                    text-decoration: underline;
                }

        /* Responsive Design */
    @@media (max-width: 992px) {
            .header-container {
                padding: 0 12px;
            }

            .logo {
                gap: 10px;
            }

            .logo-image {
                width: 80px;
                height: 80px;
            }

            .logo-text {
                font-size: 16px;
                max-width: 200px;
                line-height: 1.3;
            }

            /* Mobile toggle: visible in header and positioned for RTL */
            .nav-toggle {
                display: inline-flex;
                position: relative;
                z-index: 1300;
                width: 44px;
                height: 44px;
                align-items: center;
                justify-content: center;
                background: #eff6ff;
                border-radius: 10px;
                box-shadow: 0 2px 8px rgba(15,23,42,0.08);
                border: 1px solid #dbeafe;
                color: var(--primary-color);
                transition: all 0.2s ease;
            }

            .nav-toggle:active {
                transform: scale(0.95);
            }

            /* Collapsible nav panel */
            nav {
                position: fixed;
                top: 70px;
                right: 12px;
                left: 12px;
                background: var(--card-bg);
                border-radius: 18px;
                box-shadow: 0 18px 50px rgba(15,23,42,0.12);
                display: none;
                flex-direction: column;
                gap: 4px;
                padding: 12px 12px 16px 12px;
                z-index: 1200;
                opacity: 0;
                transform: translateY(-10px);
                transition: opacity 250ms ease, transform 250ms ease;
                max-width: 400px;
                margin: 0 auto;
                max-height: calc(100vh - 90px);
                overflow-y: auto;
                -webkit-overflow-scrolling: touch;
            }

            nav.open {
                display: flex;
                opacity: 1;
                transform: translateY(0);
            }

            nav a {
                padding: 14px 16px;
                border-radius: 12px;
                color: var(--text-primary);
                text-align: right;
                background: transparent;
                font-size: 16px;
                transition: all 0.2s ease;
                display: flex;
                align-items: center;
                gap: 12px;
                justify-content: flex-end;
            }

            nav a:hover {
                background: #eff6ff;
            }

            nav a.active {
                background: #dbeafe;
                color: var(--primary-dark);
            }

            nav a i {
                font-size: 18px;
            }

            nav form.logout-form {
                display: block !important;
                width: 100%;
                margin: 8px 0 0 0;
                padding: 0;
            }

            nav .logout-btn {
                color: var(--text-primary) !important;
                background: #f8fafc !important;
                border: 1px solid #e2e8f0;
                width: 100%;
                display: flex !important;
                justify-content: center;
                align-items: center;
                padding: 14px 16px;
                font-size: 16px;
                font-weight: 500;
                font-family: 'Tajawal', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                border-radius: 10px;
                cursor: pointer;
                gap: 8px;
                text-align: center;
                transition: all 0.2s ease;
            }

            nav .logout-btn:hover {
                background: #e2e8f0 !important;
                transform: translateY(-1px);
            }

            nav .logout-btn i {
                font-size: 16px;
            }

            .dashboard {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .card {
                padding: 16px;
                border-radius: 14px;
            }

            .card-header h2 {
                font-size: 18px;
            }

            .btn {
                padding: 12px 20px;
                font-size: 15px;
                width: 100%;
                justify-content: center;
            }

            .container {
                margin: 16px auto;
                padding: 0 12px;
            }

            footer {
                padding: 1rem 12px;
                font-size: 14px;
            }
        }

    @@media (max-width: 480px) {
            .logo-text {
                font-size: 14px;
                max-width: 160px;
            }

            .logo-image {
                width: 72px;
                height: 72px;
            }

            nav {
                right: 8px;
                left: 8px;
                padding: 10px;
            }

            nav a {
                padding: 12px 14px;
                font-size: 15px;
            }

            nav form.logout-form {
                display: block !important;
                width: 100%;
                margin: 8px 0 0 0;
                padding: 0;
            }

            nav .logout-btn {
                padding: 12px 14px;
                font-size: 15px;
                display: flex !important;
                align-items: center;
                justify-content: center;
                gap: 8px;
                color: var(--text-primary) !important;
                background: var(--light-bg) !important;
                border: 1px solid #e2e8f0;
                transition: all 0.2s ease;
            }

            nav .logout-btn:hover {
                background: #e2e8f0 !important;
            }

            .card {
                padding: 14px;
                border-radius: 10px;
            }

            .card-header h2 {
                font-size: 16px;
            }

            .card-header i {
                font-size: 20px;
            }

            .btn {
                padding: 10px 16px;
                font-size: 14px;
            }

            .container {
                padding: 0 8px;
            }

            footer {
                font-size: 13px;
            }
        }

        /* Base styles for toggle (visibility controlled by media queries) */
        .nav-toggle {
            background: transparent;
            border: none;
                color: var(--primary-color);
            font-size: 22px;
            align-items: center;
            justify-content: center;
            padding: 8px;
            border-radius: 8px;
            cursor: pointer;
        }

        .nav-toggle:focus {
            outline: 2px solid rgba(255,255,255,0.2);
        }

    @@media (min-width: 993px) {
        /* hide mobile toggle on wider screens */
        .nav-toggle { display: none !important; }
    }

        .no-underline {
            text-decoration: none;
        }

        /* Logout button styled as a nav link */
        nav form.logout-form {
            display: inline-flex;
            margin: 0;
        }

        nav .logout-btn {
            background: #eff6ff;
            color: var(--primary-color);
            text-decoration: none;
            padding: 10px 15px;
            border: 1px solid #dbeafe;
            border-radius: 999px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 1rem;
            font-family: 'Tajawal', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

            nav .logout-btn:hover {
                background: #dbeafe;
                transform: translateY(-1px);
            }
 
            .titlee { color: var(--text-primary); }
        </style>
</head>
<body>
    <a class="officer-skip" href="#main-content">تخطي إلى المحتوى</a>
    <div id="officerNavBackdrop" class="officer-nav-backdrop" aria-hidden="true"></div>

    @{
        var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);
        var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty);

        string ActiveFor(params string[] actions)
        {
            if (!string.Equals(currentController, "Officer", StringComparison.OrdinalIgnoreCase))
            {
                return string.Empty;
            }

            foreach (var a in actions)
            {
                if (string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase))
                {
                    return "active";
                }
            }

            return string.Empty;
        }
    }

    <!-- Header with Navigation -->
    <header>
        <div class="header-container">
            <div class="logo">
                <img src="~/images/logo.png" alt="شعار النظام" class="logo-image" />
                <a asp-controller="Home" asp-action="Index" class="logo-text no-underline titlee officer-brand-link">نظام المخالفات المرورية : فرع الجفرة</a>
            </div>
            <!-- Mobile nav toggle (visible on smaller screens) -->
            <button id="navToggle" class="nav-toggle" type="button" aria-expanded="false" aria-controls="officerNav" aria-label="فتح أو إغلاق قائمة التنقل" title="قائمة">
                <i class="fas fa-bars" aria-hidden="true"></i>
            </button>

            <nav id="officerNav">
                <a asp-controller="Officer" asp-action="Index" class="@ActiveFor("Index")">
                    <i class="fas fa-home"></i> لوحة التحكم
                </a>

                <a asp-controller="Officer" asp-action="IssueTicket" class="@ActiveFor("IssueTicket", "WritingTicket", "ConfirmTicket", "TicketIssued", "Receipt", "EditTicket")">
                    <i class="fas fa-ticket-alt"></i> إصدار مخالفة مرورية
                </a>

                <a asp-controller="Officer" asp-action="ScanPlate" class="@ActiveFor("ScanPlate", "SearchTickets", "DetailedTicket", "UpdateNotes")">
                    <i class="fas fa-barcode"></i> مسح المخالفات
                </a>
                <form asp-controller="Home" asp-action="Logout" method="post" class="logout-form">
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-sign-out-alt"></i> تسجيل الخروج
                    </button>
                </form>
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="officer-content-wrapper">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer>
        <p>© @DateTime.Now.Year - نظام المخالفات المرورية</p>
    </footer>

    <environment include="Development">
        <script src="~/lib/jquery/dist/jquery.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"
                asp-fallback-src="~/lib/jquery/dist/jquery.min.js"
                asp-fallback-test="window.jQuery">
        </script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
                asp-fallback-src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"
                asp-fallback-test="window.jQuery && window.jQuery.fn && window.jQuery.fn.modal">
        </script>
    </environment>

    @RenderSection("Scripts", required: false)

    <script>
        // Mobile nav toggle and active-link handling
        document.addEventListener("DOMContentLoaded", function() {
            const currentUrl = window.location.pathname || '';
            const nav = document.getElementById('officerNav');
            const toggle = document.getElementById('navToggle');
            const backdrop = document.getElementById('officerNavBackdrop');
            const navLinks = nav ? nav.querySelectorAll('a') : [];
            const mobileQuery = window.matchMedia('(max-width: 992px)');

            const isMobile = () => mobileQuery.matches;

            // Mark active links safely
            navLinks.forEach(link => {
                const linkUrl = link.getAttribute('href') || '';
                try {
                    if (linkUrl && linkUrl !== '/' && currentUrl.startsWith(linkUrl)) {
                        link.classList.add('active');
                    }
                } catch (e) {
                    // ignore malformed hrefs
                }
            });

            if (!toggle || !nav) {
                return;
            }

            const openNav = () => {
                if (!isMobile()) {
                    return;
                }

                nav.classList.add('open');
                toggle.setAttribute('aria-expanded', 'true');
                if (backdrop) {
                    backdrop.classList.add('show');
                    backdrop.setAttribute('aria-hidden', 'false');
                }
                document.body.style.overflow = 'hidden';
            };

            const closeNav = () => {
                nav.classList.remove('open');
                toggle.setAttribute('aria-expanded', 'false');
                if (backdrop) {
                    backdrop.classList.remove('show');
                    backdrop.setAttribute('aria-hidden', 'true');
                }
                document.body.style.overflow = '';
            };

            toggle.addEventListener('click', function(e) {
                e.stopPropagation();

                if (nav.classList.contains('open')) {
                    closeNav();
                } else {
                    openNav();
                }
            });

            // Close when clicking any actionable item inside nav (mobile)
            nav.addEventListener('click', function(e) {
                if (!isMobile()) {
                    return;
                }

                const clickedLink = e.target.closest('a');
                const clickedButton = e.target.closest('button');
                if (clickedLink || clickedButton) {
                    closeNav();
                }
            });

            // Close when clicking outside nav
            document.addEventListener('click', function(e) {
                if (!isMobile()) {
                    return;
                }

                if (!nav.contains(e.target) && !toggle.contains(e.target)) {
                    closeNav();
                }
            });

            // Close when pressing Escape
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && nav.classList.contains('open')) {
                    closeNav();
                }
            });

            // Close when clicking backdrop
            if (backdrop) {
                backdrop.addEventListener('click', closeNav);
            }

            // Keep nav state in sync when breakpoint changes
            const handleViewportChange = () => {
                if (!isMobile()) {
                    closeNav();
                }
            };

            if (typeof mobileQuery.addEventListener === 'function') {
                mobileQuery.addEventListener('change', handleViewportChange);
            } else {
                window.addEventListener('resize', handleViewportChange);
            }
        });
    </script>
</body>
</html>