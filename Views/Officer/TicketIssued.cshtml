@model Ticket
@inject TicketSystem.Services.IQrCodeService QrService
@{
    ViewData["Title"] = "Ticket Issued Successfully";
    Layout = "_OfficerLayout";
}
@{
    var ticketUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Ticket/Open/{Model.Ticket_Id}";
    var qrDataUri = QrService.GeneratePngDataUri(ticketUrl, 10);
}
@section Styles {
    <style>
        .ticket-issued-page {
            margin-top: 1.25rem;
        }

        .ticket-issued-card-link {
            display: block;
            text-decoration: none;
            color: inherit;
        }

        .ticket-issued-details dt,
        .ticket-issued-details dd {
            margin-bottom: 0.5rem;
        }

        .ticket-issued-qr {
            margin-top: 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .ticket-issued-qr img {
            width: 160px;
            height: 160px;
            border: 1px solid #eaeaea;
            padding: 6px;
            background: #fff;
            border-radius: 6px;
            max-width: 100%;
        }

        .ticket-issued-actions {
            margin-top: 1.25rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.625rem;
        }

        .ticket-issued-actions .btn {
            margin: 0;
        }

        @@media (max-width: 768px) {
            .ticket-issued-page {
                margin-top: 0.875rem;
                padding-inline: 0.125rem;
            }

            .ticket-issued-page .alert h4 {
                font-size: 1rem;
                line-height: 1.45;
            }

            .ticket-issued-page .card-header h4 {
                font-size: 1.05rem;
                margin-bottom: 0;
                line-height: 1.4;
            }

            .ticket-issued-details dt,
            .ticket-issued-details dd {
                width: 100%;
                max-width: 100%;
            }

            .ticket-issued-details dt {
                font-weight: 700;
                margin-top: 0.4rem;
            }

            .ticket-issued-qr {
                flex-direction: column;
                align-items: stretch;
                text-align: center;
            }

            .ticket-issued-qr > div:first-child {
                display: flex;
                justify-content: center;
            }

            .ticket-issued-actions {
                flex-direction: column;
            }

            .ticket-issued-actions .btn {
                width: 100%;
                justify-content: center;
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
            }
        }
    </style>
}

        <div class="container ticket-issued-page">
            <div class="alert alert-success">
                <h4><i class="fas fa-check-circle"></i> @ViewData["SuccessMessage"]</h4>
            </div>
        <a asp-action="DetailedTicket" asp-controller="Officer" asp-route-id="@Model.Ticket_Id" class="ticket-issued-card-link">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h4>Ticket #@Model.Ticket_Id Issued Successfully</h4>
                    </div>
                    <div class="card-body">
                        <dl class="row ticket-issued-details">
                            <dt class="col-sm-3">Ticket Number:</dt>
                            <dd class="col-sm-9">@Model.Ticket_Id</dd>

                            <dt class="col-sm-3">Violations:</dt>
                            <dd class="col-sm-9">@Model.Violations</dd>

                            <dt class="col-sm-3">License Plate:</dt>
                            <dd class="col-sm-9">@Model.Plate_Number</dd>

                            <dt class="col-sm-3">Fine Amount:</dt>
                            <dd class="col-sm-9">@Model.FineAmount.ToString("C")</dd>

                            <dt class="col-sm-3">Issued On:</dt>
                            <dd class="col-sm-9">@DateTime.Now.ToString("g")</dd>
                        </dl>
                        <div class="ticket-issued-qr">
                            <div>
                                <img src="@qrDataUri" alt="Ticket QR" />
                            </div>
                            <div>
                                <p class="mb-1 fw-bold">Scan to view ticket</p>
                                <small class="text-muted">Opens: @ticketUrl</small>
                            </div>
                        </div>
                    </div>
                </div>
            </a>

            <div class="ticket-issued-actions">
                <a asp-action="IssueTicket" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Issue Another Ticket
                </a>
                <a asp-action="Receipt" asp-route-id="@Model.Ticket_Id" target="_blank" rel="noopener"
                   class="btn btn-outline-dark">
                    <i class="fas fa-print"></i> Print Receipt (Signature)
                </a>
                <a asp-action="Index" asp-controller="Officer" class="btn btn-secondary">
                    <i class="fas fa-home"></i> Return to Dashboard
                </a>
            </div>
        </div>

