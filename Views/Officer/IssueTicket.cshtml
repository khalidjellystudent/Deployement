@using TicketSystem.Models
@model Ticket
@{
    ViewData["Title"] = "إصدار مخالفة جديدة";
    Layout = "_OfficerLayout";

    var violations = ViewBag.Violations as List<Violation> ?? new List<Violation>();
    var selectedNames = (Model?.Violations ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(v => v.Trim())
        .ToHashSet(StringComparer.Ordinal);
}
    <div class="container-fluid">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5><i class="fas fa-ticket-alt me-2"></i>إصدار مخالفة مرورية</h5>
            </div>
            <div class="card-body">
                <!-- رسالة النجاح -->
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Success"]
                    </div>
                }

                <form id="issueTicketForm" asp-action="WritingTicket" method="post" enctype="multipart/form-data">
                    <!-- رقم المخالفة (تلقائي) -->
                    <div class="mb-3" hidden>
                        <label class="form-label">رقم المخالفة</label>
                        <input asp-for="Ticket_Id" class="form-control" readonly />
                    </div>

                    <!-- بريد السائق -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">البريد الإلكتروني للسائق</label>
                        <input asp-for="Email" class="form-control" placeholder="driverid@example.com" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- اسم الضابط (مخفي) -->
                    <div class="mb-3">
                        <input type="hidden" asp-for="IssuedBy" />
                    </div>

                    <!-- مكان المخالفة -->
                    <div class="mb-3">
                        <label asp-for="Violation_Place" class="form-label">مكان المخالفة</label>
                        <div class="input-group">
                            <input asp-for="Violation_Place"
                                   id="Violation_Place"
                                   class="form-control"
                                   placeholder="مثال: شارع ... أو إحداثيات GPS مثل 24.7136, 46.6753"
                                   required>
                            <button type="button" id="btnUseGps" class="btn btn-outline-secondary">
                                <i class="fas fa-location-crosshairs me-1"></i>استخدم موقعي
                            </button>
                        </div>
                        <div id="gpsStatus" class="form-text"></div>
                        <span asp-validation-for="Violation_Place" class="text-danger"></span>
                    </div>

                    <!-- رقم اللوحة + التقاط الكاميرا -->
                    <div class="mb-3">
                        <label asp-for="Plate_Number" class="form-label">رقم اللوحة</label>
                        <div class="input-group">
                            <input asp-for="Plate_Number" class="form-control" id="Plate_Number" placeholder="1234" required />
                            <button type="button" class="btn btn-outline-primary" id="btnCapturePlate">
                                <i class="fas fa-camera me-1"></i>التقاط والتعرف
                            </button>
                        </div>
                        <div class="form-text">سيفتح الكاميرا ويلتقط لقطة واحدة ويرسلها لخدمة التعرف على اللوحات.</div>
                        <span asp-validation-for="Plate_Number" class="text-danger"></span>

                        <div id="lpr-camera" class="mt-3 border rounded p-3" style="display:none;">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div class="fw-semibold">الكاميرا المباشرة</div>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnStartCamera">
                                        <i class="fas fa-play me-1"></i>تشغيل
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnStopCamera">
                                        <i class="fas fa-stop me-1"></i>إيقاف
                                    </button>
                                </div>
                            </div>
                            <div class="mt-2">
                                <video id="lprVideo" class="w-100 rounded border" autoplay playsinline muted style="max-height:280px;"></video>
                            </div>
                            <div id="lprStatus" class="form-text mt-2"></div>
                        </div>

                        <div class="mt-3">
                            <div class="fw-semibold mb-1">صورة المخالفة المطلوبة</div>
                            <div class="input-group">
                                <input type="file" class="form-control" id="evidenceImage" name="evidenceImage" accept="image/*" aria-label="رفع صورة المخالفة" required />
                                <button type="button" class="btn btn-outline-primary" id="btnUploadLpr">
                                    <i class="fas fa-upload me-1"></i>رفع والتعرف
                                </button>
                            </div>
                            <div class="form-text">مسموح برفع الصور فقط؛ لن يتم قبول أي ملفات أخرى.</div>
                        </div>
                    </div>

                    <!-- تقرير المخالفة النصي -->
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label" >ملاحظات</label>
                        <input asp-for="Notes" class="form-control" placeholder="ملاحظات حول إصدار المخالفة" required />
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <!-- تقرير صوتي (اختياري) -->
                    <div class="mb-3">
                        <label class="form-label">تقرير صوتي للضابط (اختياري)</label>
                        <div class="input-group">
                            <input type="file" class="form-control" name="voiceReport" id="voiceReport" accept="audio/*" />
                            <button type="button" class="btn btn-outline-secondary" id="btnPreviewAudio">معاينة</button>
                        </div>
                        <div class="d-flex gap-2 mt-2 flex-wrap">
                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnStartRecord">
                                <i class="fas fa-microphone me-1"></i>بدء التسجيل
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" id="btnStopRecord" disabled>
                                <i class="fas fa-stop me-1"></i>إيقاف وحفظ
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnClearAudio">
                                <i class="fas fa-trash me-1"></i>مسح الملف
                            </button>
                        </div>
                        <div id="audioStatus" class="form-text"></div>
                        <audio id="audioPreview" class="mt-2 w-100" controls style="display:none;"></audio>
                    </div>

                    <!-- قائمة أنواع المخالفات -->
                    <div class="mb-3">
                        <label class="form-label">أنواع المخالفات</label>
                        <div id="violation-list" class="d-flex flex-wrap gap-3">
                            @if (!violations.Any())
                            {
                                <div class="alert alert-warning mb-0">
                                    لا توجد مخالفات مُفعّلة حالياً. الرجاء التواصل مع المسؤول لإضافتها.
                                </div>
                            }
                            else
                            {
                                foreach (var violation in violations)
                                {
                                    <label class="form-check-label d-flex align-items-center">
                                        <input class="form-check-input me-2 violation-checkbox"
                                               type="checkbox"
                                               name="ViolationIds"
                                               value="@violation.Id"
                                               data-cost="@violation.Cost"
                                               @(selectedNames.Contains(violation.Name) ? "checked" : null) />
                                        <span>@violation.Name</span>
                                    </label>
                                }
                            }
                        </div>
                        <div id="violation-error" class="text-danger mt-1" style="display:none;">
                            يجب اختيار مخالفة واحدة على الأقل قبل إصدار التذكرة.
                        </div>
                    </div>

                    <!-- مبلغ الغرامة (مخفي) -->
                    <div class="mb-3" hidden>
                        <label asp-for="FineAmount" class="form-label">مبلغ الغرامة</label>
                        <input asp-for="FineAmount"
                               id="fineamount"
                               class="form-control" />
                    </div>

                    <!-- تاريخ الاستحقاق -->
                    <div class="col-md-3">
                        <label asp-for="Due_Date" class="form-label">تاريخ الاستحقاق</label>
                        <input asp-for="Due_Date" type="date" class="form-control" required min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-paper-plane me-2"></i>إصدار المخالفة
                        </button>
                    </div>
                    <p>@ViewData["m"]</p>
                </form>
            </div>
        </div>
    </div>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const fineAmountInput = document.getElementById("fineamount");
            const checkboxes = document.querySelectorAll(".violation-checkbox");
            const form = document.getElementById("issueTicketForm");
            const errorMsg = document.getElementById("violation-error");

            // LPR elements
            const plateInput = document.getElementById("Plate_Number");
            const btnCapturePlate = document.getElementById("btnCapturePlate");
            const btnStartCamera = document.getElementById("btnStartCamera");
            const btnStopCamera = document.getElementById("btnStopCamera");
            const btnUploadLpr = document.getElementById("btnUploadLpr");
            const lprUpload = document.getElementById("evidenceImage");
            const lprWrapper = document.getElementById("lpr-camera");
            const lprVideo = document.getElementById("lprVideo");
            const lprStatus = document.getElementById("lprStatus");
            const antiForgery = form?.querySelector('input[name="__RequestVerificationToken"]');
            const lprCanvas = document.createElement("canvas");
            let lprStream = null;
            const voiceInput = document.getElementById("voiceReport");
            const btnPreviewAudio = document.getElementById("btnPreviewAudio");
            const audioPreview = document.getElementById("audioPreview");
            const audioStatus = document.getElementById("audioStatus");
            const btnStartRecord = document.getElementById("btnStartRecord");
            const btnStopRecord = document.getElementById("btnStopRecord");
            const btnClearAudio = document.getElementById("btnClearAudio");
            let mediaRecorder = null;
            let recordedChunks = [];

            // GPS helpers
            const btnGps = document.getElementById("btnUseGps");
            const placeInput = document.getElementById("Violation_Place");
            const gpsStatus = document.getElementById("gpsStatus");

            function setGpsStatus(message, type = "muted") {
                if (!gpsStatus) return;
                const classes = ["text-muted", "text-success", "text-warning", "text-danger"];
                gpsStatus.classList.remove(...classes);
                gpsStatus.classList.add(`text-${type}`);
                gpsStatus.textContent = message || "";
            }

            function setLprStatus(message, type = "muted") {
                if (!lprStatus) return;
                const classes = ["text-muted", "text-success", "text-warning", "text-danger", "text-info"];
                lprStatus.classList.remove(...classes);
                lprStatus.classList.add(`text-${type}`);
                lprStatus.textContent = message || "";
            }

            function setAudioStatus(message, type = "muted") {
                if (!audioStatus) return;
                const classes = ["text-muted", "text-success", "text-warning", "text-danger", "text-info"];
                audioStatus.classList.remove(...classes);
                audioStatus.classList.add(`text-${type}`);
                audioStatus.textContent = message || "";
            }

            function clearAudioSelection() {
                if (voiceInput) {
                    voiceInput.value = "";
                }
                if (audioPreview) {
                    audioPreview.pause();
                    audioPreview.removeAttribute("src");
                    audioPreview.style.display = "none";
                }
                setAudioStatus("تم مسح الملف الصوتي.", "muted");
            }

            function useCurrentLocation() {
                if (!navigator.geolocation) {
                    setGpsStatus("المتصفح لا يدعم تحديد الموقع الجغرافي.", "danger");
                    return;
                }

                const originalHtml = btnGps.innerHTML;
                btnGps.disabled = true;
                btnGps.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>جارِ تحديد الموقع...';
                setGpsStatus("قد يطلب المتصفح إذن الوصول إلى الموقع...", "muted");

                const isSecure = location.protocol === "https:" || location.hostname === "localhost" || location.hostname === "127.0.0.1";
                if (!isSecure) {
                    setGpsStatus("قد يفشل تحديد الموقع بدون اتصال HTTPS (باستثناء localhost).", "warning");
                }

                navigator.geolocation.getCurrentPosition(
                    (pos) => {
                        const lat = pos.coords.latitude.toFixed(6);
                        const lng = pos.coords.longitude.toFixed(6);
                        placeInput.value = `${lat}, ${lng}`;
                        setGpsStatus("تم ملء الحقل بإحداثيات موقعك الحالية.", "success");
                        btnGps.disabled = false;
                        btnGps.innerHTML = originalHtml;
                    },
                    (err) => {
                        let msg = "تعذر تحديد الموقع.";
                        if (err.code === err.PERMISSION_DENIED) msg = "تم رفض إذن الموقع. يرجى السماح بالوصول للموقع من المتصفح.";
                        else if (err.code === err.POSITION_UNAVAILABLE) msg = "معلومات الموقع غير متاحة حالياً.";
                        else if (err.code === err.TIMEOUT) msg = "انتهت مهلة تحديد الموقع. حاول مرة أخرى.";
                        setGpsStatus(msg, "danger");
                        btnGps.disabled = false;
                        btnGps.innerHTML = originalHtml;
                    },
                    { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
                );
            }

            btnGps?.addEventListener("click", useCurrentLocation);

            async function startCamera() {
                if (!lprWrapper) return;
                lprWrapper.style.display = "block";

                if (!navigator.mediaDevices?.getUserMedia) {
                    setLprStatus("المتصفح لا يدعم تشغيل الكاميرا.", "danger");
                    return;
                }

                if (lprStream) {
                    setLprStatus("الكاميرا جاهزة.", "success");
                    return;
                }

                try {
                    setLprStatus("جاري تشغيل الكاميرا...", "info");
                    lprStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } });
                    lprVideo.srcObject = lprStream;
                    setLprStatus("الكاميرا تعمل. اضغط التقاط للتعرف.", "success");
                }
                catch (err) {
                    setLprStatus("تعذر تشغيل الكاميرا: " + err.message, "danger");
                }
            }

            function stopCamera(keepStatus = false) {
                if (lprStream) {
                    lprStream.getTracks().forEach(t => t.stop());
                    lprStream = null;
                }
                if (lprVideo) {
                    lprVideo.srcObject = null;
                }
                if (!keepStatus) {
                    setLprStatus("تم إيقاف الكاميرا.", "muted");
                }
            }

            function updateFineAmount() {
                let total = 0;
                checkboxes.forEach(cb => {
                    if (cb.checked) {
                        const cost = parseFloat(cb.dataset.cost || "0");
                        total += isNaN(cost) ? 0 : cost;
                    }
                });
                fineAmountInput.value = total;
            }

            checkboxes.forEach(cb => {
                cb.addEventListener("change", updateFineAmount);
            });

            async function captureAndRecognize() {
                if (!btnCapturePlate) return;

                lprWrapper?.style.setProperty("display", "block");
                await startCamera();
                if (!lprStream || !lprVideo || !lprCanvas) return;

                const originalLabel = btnCapturePlate.innerHTML;
                btnCapturePlate.disabled = true;
                btnCapturePlate.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>جارٍ التعرف...';
                setLprStatus("جارٍ التقاط صورة وإرسالها للتعرف...", "info");

                lprCanvas.width = lprVideo.videoWidth || 640;
                lprCanvas.height = lprVideo.videoHeight || 480;
                const ctx = lprCanvas.getContext("2d");
                ctx.drawImage(lprVideo, 0, 0, lprCanvas.width, lprCanvas.height);

                lprCanvas.toBlob(async (blob) => {
                    if (!blob) {
                        setLprStatus("تعذر إنشاء الصورة الملتقطة.", "danger");
                        btnCapturePlate.disabled = false;
                        btnCapturePlate.innerHTML = originalLabel;
                        stopCamera(true);
                        return;
                    }

                        const file = new File([blob], "evidence.jpg", { type: "image/jpeg" });
                        const dt = new DataTransfer();
                        dt.items.add(file);
                        if (lprUpload) {
                            lprUpload.files = dt.files;
                        }

                    const formData = new FormData();
                        formData.append("file", file);
                    if (antiForgery) formData.append(antiForgery.name, antiForgery.value);

                    try {
                        const resp = await fetch("@Url.Action("RecognizeFrame", "Lpr")", { method: "POST", body: formData });
                        const data = await resp.json();

                        if (!resp.ok) {
                            const detail = data?.error || data?.detail || "تعذر التعرف على اللوحة.";
                            throw new Error(detail);
                        }

                        if (data?.plate) {
                            plateInput.value = data.plate.toUpperCase();
                            const confidenceText = typeof data?.confidencePercentage === "number"
                                ? ` (نسبة الثقة: ${data.confidencePercentage.toFixed(2)}%)`
                                : "";
                            setLprStatus("تم ملء رقم اللوحة تلقائياً: " + data.plate + confidenceText, "success");
                        }
                        else {
                            setLprStatus("لم يتم العثور على لوحة في اللقطة، حاول مرة أخرى.", "warning");
                        }
                    }
                    catch (err) {
                        setLprStatus("فشل التعرف: " + err.message, "danger");
                    }
                    finally {
                        btnCapturePlate.disabled = false;
                        btnCapturePlate.innerHTML = originalLabel;
                        stopCamera(true); // release webcam and keep recognition result text visible
                    }
                }, "image/jpeg", 0.9);
            }

            async function uploadAndRecognize() {
                if (!lprUpload || !lprUpload.files?.length) {
                    setLprStatus("يرجى اختيار صورة للوحة.", "warning");
                    return;
                }

                const file = lprUpload.files[0];
                if (!file.type || !file.type.startsWith("image/")) {
                    setLprStatus("فقط صور اللوحات مسموح بها.", "danger");
                    lprUpload.value = "";
                    return;
                }

                const originalLabel = btnUploadLpr.innerHTML;
                btnUploadLpr.disabled = true;
                btnUploadLpr.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>جارٍ التعرف...';
                setLprStatus("جارٍ إرسال الصورة للتعرف...", "info");

                const formData = new FormData();
                formData.append("file", file);
                if (antiForgery) formData.append(antiForgery.name, antiForgery.value);

                try {
                    const resp = await fetch("@Url.Action("RecognizeFrame", "Lpr")", { method: "POST", body: formData });
                    const data = await resp.json();

                    if (!resp.ok) {
                        const detail = data?.error || data?.detail || "تعذر التعرف على اللوحة.";
                        throw new Error(detail);
                    }

                    if (data?.plate) {
                        plateInput.value = data.plate.toUpperCase();
                        const confidenceText = typeof data?.confidencePercentage === "number"
                            ? ` (نسبة الثقة: ${data.confidencePercentage.toFixed(2)}%)`
                            : "";
                        setLprStatus("تم ملء رقم اللوحة تلقائياً: " + data.plate + confidenceText, "success");
                    }
                    else {
                        setLprStatus("لم يتم العثور على لوحة في الصورة.", "warning");
                    }
                }
                catch (err) {
                    setLprStatus("فشل التعرف: " + err.message, "danger");
                }
                finally {
                    btnUploadLpr.disabled = false;
                    btnUploadLpr.innerHTML = originalLabel;
                }
            }

            if (form) {
                form.addEventListener("submit", function (e) {
                    const anyChecked = Array.from(checkboxes).some(cb => cb.checked);
                    if (!anyChecked) {
                        e.preventDefault();
                        errorMsg.style.display = "block";
                    } else {
                        errorMsg.style.display = "none";
                    }
                });
            }

            btnCapturePlate?.addEventListener("click", captureAndRecognize);
            btnStartCamera?.addEventListener("click", startCamera);
            btnStopCamera?.addEventListener("click", stopCamera);
            btnUploadLpr?.addEventListener("click", uploadAndRecognize);

            btnPreviewAudio?.addEventListener("click", function () {
                if (!voiceInput || !voiceInput.files?.length) {
                    setAudioStatus("يرجى اختيار ملف صوتي للمعاينة.", "warning");
                    return;
                }
                const file = voiceInput.files[0];
                if (!file.type || !file.type.startsWith("audio/")) {
                    setAudioStatus("يُسمح بملفات الصوت فقط.", "danger");
                    voiceInput.value = "";
                    audioPreview.style.display = "none";
                    audioPreview.removeAttribute("src");
                    return;
                }
                const url = URL.createObjectURL(file);
                audioPreview.src = url;
                audioPreview.style.display = "block";
                audioPreview.play().catch(() => {});
                setAudioStatus("تم تجهيز المعاينة.", "success");
            });

            btnClearAudio?.addEventListener("click", clearAudioSelection);

            btnStartRecord?.addEventListener("click", async function () {
                if (!navigator.mediaDevices?.getUserMedia) {
                    setAudioStatus("المتصفح لا يدعم تسجيل الصوت.", "danger");
                    return;
                }
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    recordedChunks = [];
                    mediaRecorder = new MediaRecorder(stream);
                    mediaRecorder.ondataavailable = (e) => {
                        if (e.data.size > 0) recordedChunks.push(e.data);
                    };
                    mediaRecorder.onstop = () => {
                        const blob = new Blob(recordedChunks, { type: "audio/webm" });
                        const file = new File([blob], "voiceReport.webm", { type: "audio/webm" });
                        const dt = new DataTransfer();
                        dt.items.add(file);
                        voiceInput.files = dt.files;
                        const url = URL.createObjectURL(blob);
                        audioPreview.src = url;
                        audioPreview.style.display = "block";
                        audioPreview.play().catch(() => {});
                        setAudioStatus("تم حفظ التسجيل ويمكن معاينته.", "success");
                    };
                    mediaRecorder.start();
                    setAudioStatus("جاري التسجيل... اضغط إيقاف لحفظ الملف.", "info");
                    btnStartRecord.disabled = true;
                    btnStopRecord.disabled = false;
                } catch (err) {
                    setAudioStatus("تعذر بدء التسجيل: " + err.message, "danger");
                }
            });

            btnStopRecord?.addEventListener("click", function () {
                if (mediaRecorder && mediaRecorder.state === "recording") {
                    mediaRecorder.stop();
                    mediaRecorder.stream.getTracks().forEach(t => t.stop());
                }
                btnStartRecord.disabled = false;
                btnStopRecord.disabled = true;
            });

            window.addEventListener("beforeunload", stopCamera);

            updateFineAmount();
        });
    </script>
}