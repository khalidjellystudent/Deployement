@model TicketSystem.Models.Ticket
@inject TicketSystem.Services.IQrCodeService QrService
@{
    ViewData["Title"] = $"Ticket #{Model.Ticket_Id}";
    Layout = "_OfficerLayout";

    var ticketUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Ticket/Open/{Model.Ticket_Id}";
    var qrDataUri = QrService.GeneratePngDataUri(ticketUrl, 10);
    var amountText = Model.FineAmount.ToString("0.##");
}

@section Styles {
    <style>
        .ticket-detail-page {
            max-width: 1100px;
            margin-inline: auto;
            padding-bottom: 1rem;
        }

        .ticket-hero {
            position: relative;
            overflow: hidden;
            border: 0;
            border-radius: 24px;
            background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 52%, #0ea5e9 100%);
            color: #fff;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.24);
        }

        .ticket-hero::after {
            content: "";
            position: absolute;
            inset: auto -10% -35% auto;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.08);
            filter: blur(2px);
        }

        .ticket-hero__content {
            position: relative;
            z-index: 1;
            padding: 1.4rem 1.5rem;
        }

        .ticket-kicker {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.35rem 0.7rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.12);
            color: rgba(255, 255, 255, 0.96);
            font-size: 0.88rem;
        }

        .ticket-hero h1 {
            margin: 0.85rem 0 0.45rem;
            font-size: clamp(1.45rem, 3vw, 2.2rem);
            font-weight: 700;
        }

        .ticket-hero p {
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 0;
        }

        .ticket-hero-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            margin-top: 1rem;
        }

        .ticket-summary-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .summary-card {
            border: 1px solid #e8eef8;
            border-radius: 18px;
            background: #fff;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.05);
            padding: 1rem;
            min-height: 100%;
        }

        .summary-card .label {
            display: block;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6b7280;
            margin-bottom: 0.45rem;
        }

        .summary-card .value {
            font-size: 1rem;
            font-weight: 700;
            color: #111827;
            word-break: break-word;
        }

        .summary-card .hint {
            display: block;
            margin-top: 0.35rem;
            color: #6b7280;
            font-size: 0.85rem;
        }

        .ticket-panel {
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            box-shadow: 0 16px 36px rgba(15, 23, 42, 0.06);
            overflow: hidden;
        }

        .ticket-panel .card-header {
            background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
            border-bottom: 1px solid #edf2f7;
            padding: 1rem 1.25rem;
        }

        .ticket-panel .card-body {
            padding: 1.25rem;
        }

        .ticket-section-title {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            margin-bottom: 1rem;
            font-size: 1rem;
            font-weight: 700;
            color: #111827;
        }

        .ticket-section-title i {
            color: #1d4ed8;
        }

        .ticket-details-list dt,
        .ticket-details-list dd {
            padding-top: 0.35rem;
            padding-bottom: 0.35rem;
        }

        .ticket-details-list dt {
            color: #6b7280;
            font-weight: 600;
        }

        .ticket-details-list dd {
            color: #111827;
            margin-bottom: 0;
            word-break: break-word;
        }

        .ticket-note-box {
            padding: 1rem;
            border-radius: 16px;
            background: linear-gradient(180deg, #f9fafb 0%, #ffffff 100%);
            border: 1px solid #eef2f7;
        }

        .ticket-note-box p {
            margin-bottom: 0;
            color: #374151;
            line-height: 1.75;
        }

        .ticket-qr-block {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem;
            border-radius: 18px;
            background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
            border: 1px solid #e6eefb;
        }

        .ticket-qr-image {
            width: 150px;
            height: 150px;
            border: 1px solid #e5e7eb;
            padding: 8px;
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
            flex: 0 0 auto;
        }

        .ticket-qr-copy p {
            margin-bottom: 0.2rem;
            font-weight: 700;
            color: #111827;
        }

        .ticket-qr-copy small {
            word-break: break-all;
        }

        .ticket-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            justify-content: space-between;
        }

        .ticket-actions .action-group {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .ticket-actions .btn {
            min-width: 0;
            border-radius: 12px;
            padding-inline: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
        }

        @@media (max-width: 991px) {
            .ticket-summary-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 768px) {
            .ticket-detail-page {
                padding-inline: 0.25rem;
            }

            .ticket-hero__content,
            .ticket-panel .card-body,
            .ticket-panel .card-header {
                padding-left: 1rem;
                padding-right: 1rem;
            }

            .ticket-summary-grid {
                grid-template-columns: 1fr;
                gap: 0.75rem;
            }

            .ticket-qr-block {
                flex-direction: column;
                align-items: flex-start;
            }

            .ticket-qr-image {
                width: 120px;
                height: 120px;
            }

            .ticket-actions,
            .ticket-actions .action-group {
                width: 100%;
            }

            .ticket-actions .btn,
            .ticket-actions form {
                width: 100%;
            }

            .ticket-actions .btn {
                width: 100%;
            }
        }
    </style>
}

<div class="ticket-detail-page" dir="rtl">
    <div class="ticket-hero mb-4">
        <div class="ticket-hero__content">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <span class="ticket-kicker">
                        <i class="fas fa-ticket-alt"></i>
                        صفحة المخالفة
                    </span>
                    <h1>تفاصيل المخالفة رقم @Model.Ticket_Id</h1>
                    <p>مراجعة سريعة للمخالفة، معلومات السائق، والملاحظات من مكان واحد.</p>
                </div>

                <span class="badge @GetStatusBadgeClass(Model.Status) align-self-start fs-6 px-3 py-2 rounded-pill">
                    @GetStatusText(Model.Status)
                </span>
            </div>

            <div class="ticket-hero-meta">
                <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                    <i class="fas fa-car ms-1"></i> @Model.Plate_Number
                </span>
                <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                    <i class="fas fa-calendar-day ms-1"></i> @Model.Ticket_Time.ToString("yyyy/MM/dd")
                </span>
                <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                    <i class="fas fa-coins ms-1"></i> @amountText
                </span>
            </div>
        </div>
    </div>

    <div class="ticket-summary-grid">
        <div class="summary-card">
            <span class="label">المبلغ المستحق</span>
            <div class="value">@amountText</div>
            <span class="hint">قيمة الغرامة المسجلة</span>
        </div>
        <div class="summary-card">
            <span class="label">آخر موعد للسداد</span>
            <div class="value">@Model.Due_Date.ToShortDateString()</div>
            <span class="hint">الموعد المحدد للإجراء</span>
        </div>
        <div class="summary-card">
            <span class="label">الحالة</span>
            <div class="value">@GetStatusText(Model.Status)</div>
            <span class="hint">@GetStatusHint(Model.Status)</span>
        </div>
        <div class="summary-card">
            <span class="label">المرجع</span>
            <div class="value">#@Model.Ticket_Id</div>
            <span class="hint">رابط المشاركة السريع متاح عبر رمز QR</span>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-lg-7">
            <div class="card ticket-panel h-100">
                <div class="card-header">
                    <div class="ticket-section-title mb-0">
                        <i class="fas fa-clipboard-list"></i>
                        معلومات المخالفة
                    </div>
                </div>
                <div class="card-body">
                    <partial name="_TicketDetails" model="Model" view-data='new ViewDataDictionary(ViewData)
                    {
                        ["PlateLabel"] = "رقم اللوحة",
                        ["ViolationsLabel"] = "نوع المخالفة",
                        ["LocationLabel"] = "موقع المخالفة",
                        ["IssuedOnLabel"] = "تاريخ الإصدار",
                        ["DueDateLabel"] = "تاريخ الاستحقاق",
                        ["IssuedByLabel"] = "صادر بواسطة",
                        ["EvidenceLabel"] = "صورة المخالفة"
                    }' />

                    <div class="mt-4">
                        <div class="ticket-section-title">
                            <i class="fas fa-qrcode"></i>
                            بطاقة الوصول السريع
                        </div>
                        <div class="ticket-qr-block">
                            <img src="@qrDataUri" alt="Ticket QR" class="ticket-qr-image" />
                            <div class="ticket-qr-copy">
                                <p>امسح الرمز لفتح تفاصيل المخالفة</p>
                                <small class="text-muted">@ticketUrl</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card ticket-panel h-100">
                <div class="card-header">
                    <div class="ticket-section-title mb-0">
                        <i class="fas fa-user"></i>
                        بيانات السائق
                    </div>
                </div>
                <div class="card-body">
                    <dl class="row ticket-details-list mb-0">
                        <dt class="col-sm-4">الاسم الكامل</dt>
                        <dd class="col-sm-8">@Model.Users?.Name</dd>

                        <dt class="col-sm-4">البريد الإلكتروني</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">حالة الرخصة</dt>
                        <dd class="col-sm-8">
                            <span class="badge @GetLicenseBadgeClass(Model.Users?.License_Status ?? string.Empty)">
                                @Model.Users?.License_Status
                            </span>
                        </dd>

                        <dt class="col-sm-4">العنوان</dt>
                        <dd class="col-sm-8">@Model.Users?.Address</dd>

                        <dt class="col-sm-4">فصيلة الدم</dt>
                        <dd class="col-sm-8">@Model.Users?.Blood_Type</dd>

                        <dt class="col-sm-4">تاريخ الميلاد</dt>
                        <dd class="col-sm-8">@Model.Users?.Birth_Date.ToShortDateString()</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card ticket-panel">
                <div class="card-header">
                    <div class="ticket-section-title mb-0">
                        <i class="fas fa-note-sticky"></i>
                        ملاحظات الموظف
                    </div>
                </div>
                <div class="card-body">
                    @if (string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <div class="ticket-note-box">
                            <p>لا توجد ملاحظات إضافية مسجلة.</p>
                        </div>
                    }
                    else
                    {
                        <div class="ticket-note-box">
                            <p>@Model.Notes</p>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.VoiceReportPath))
                    {
                        <div class="mt-3">
                            <div class="ticket-section-title mb-2">
                                <i class="fas fa-microphone-lines"></i>
                                التقرير الصوتي
                            </div>
                            <audio src="@Model.VoiceReportPath" controls class="w-100"></audio>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card ticket-panel mt-4">
        <div class="card-body">
            <div class="ticket-actions">
                <div class="action-group">
                    <a asp-action="Receipt" asp-route-id="@Model.Ticket_Id" target="_blank" rel="noopener" class="btn btn-outline-dark">
                        <i class="fas fa-print"></i>
                        طباعة الإيصال
                    </a>
                    <a asp-action="SearchTickets" asp-route-plateNumber="@Model.Plate_Number" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i>
                        العودة إلى البحث
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Paid" => "bg-success",
            "Pending" => "bg-warning text-dark",
            "UnderProcess" => "bg-info text-white",
            "Rejected" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    string GetStatusText(string status)
    {
        return status switch
        {
            "Paid" => "مدفوعة",
            "Pending" => "قيد الانتظار",
            "UnderProcess" => "قيد المعالجة",
            "Rejected" => "مرفوضة",
            _ => status
        };
    }

    string GetStatusHint(string status)
    {
        return status switch
        {
            "Paid" => "تمت تسوية المخالفة ويمكن حفظ الإيصال.",
            "Pending" => "المخالفة بانتظار السداد.",
            "UnderProcess" => "المخالفة قيد المراجعة أو الإجراء.",
            "Rejected" => "تم رفض الطلب المرتبط بهذه المخالفة.",
            _ => "راجع حالة المخالفة من الصفحة الحالية."
        };
    }

    string GetLicenseBadgeClass(string status)
    {
        return status switch
        {
            "Valid" => "bg-success",
            "Expired" => "bg-warning text-dark",
            "Suspended" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}