@model TicketSystem.Models.Ticket
@inject TicketSystem.Services.IQrCodeService QrService
@{
    ViewData["Title"] = $"Ticket #{Model.Ticket_Id}";
    Layout = "_OfficerLayout";
}
@{ var ticketUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Ticket/Open/{Model.Ticket_Id}"; var qrDataUri = QrService.GeneratePngDataUri(ticketUrl, 10); }
@section Styles {
    <style>
        .detailed-ticket-page .card { border-radius: 8px; }
        .detailed-ticket-page .card-header { border-radius: 8px 8px 0 0 !important; }
        .detailed-ticket-page dt { font-weight: 600; color: #495057; }
        .detailed-ticket-page dd { margin-bottom: 0.75rem; }

        .ticket-topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }

        .ticket-topbar h2 {
            margin-bottom: 0;
            line-height: 1.35;
        }

        .ticket-topbar-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .ticket-page-actions {
            margin-top: 1rem;
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .ticket-details-list dt,
        .ticket-details-list dd,
        .driver-details-list dt,
        .driver-details-list dd {
            word-break: break-word;
        }

        .ticket-qr-section {
            margin-top: 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .ticket-qr-image {
            width: 160px;
            height: 160px;
            border: 1px solid #eaeaea;
            padding: 6px;
            background: #fff;
            border-radius: 6px;
            max-width: 100%;
        }

        @@media (max-width: 768px) {
            .detailed-ticket-page {
                padding-inline: 0.2rem;
            }

            .ticket-topbar {
                align-items: stretch;
            }

            .ticket-topbar h2 {
                font-size: 1.25rem;
            }

            .ticket-topbar-actions {
                width: 100%;
                flex-direction: column;
            }

            .ticket-topbar-actions .btn {
                width: 100%;
                justify-content: center;
                display: inline-flex;
                align-items: center;
            }

            .ticket-page-actions {
                width: 100%;
                flex-direction: column;
            }

            .ticket-page-actions .btn {
                width: 100%;
                justify-content: center;
                display: inline-flex;
                align-items: center;
            }

            .ticket-details-list dt,
            .ticket-details-list dd,
            .driver-details-list dt,
            .driver-details-list dd {
                width: 100%;
                max-width: 100%;
            }

            .ticket-details-list dt,
            .driver-details-list dt {
                margin-top: 0.4rem;
            }

            .ticket-qr-section {
                flex-direction: column;
                align-items: center;
                text-align: center;
            }

            .ticket-qr-meta {
                width: 100%;
                overflow-wrap: anywhere;
            }

            .ticket-qr-image {
                width: 120px;
                height: 120px;
            }
        }

        @@media print {
            nav { display: none !important; }
            .ticket-container { box-shadow: none; margin: 0; }
        }
    </style>
}

<div class="container-fluid detailed-ticket-page">
        <div class="ticket-topbar">
            <h2>
                <i class="fas fa-ticket-alt me-2"></i>
                Ticket #@Model.Ticket_Id
                <span class="badge @GetStatusBadgeClass(Model.Status) ms-2">
                    @Model.Status
                </span>
            </h2>
        </div>

        <div class="row">
            <!-- Left Column - Ticket Details -->
            <div class="col-lg-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-exclamation-circle me-2"></i> Violation Details</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row ticket-details-list">
                            <dt class="col-sm-4">Plate Number</dt>
                            <dd class="col-sm-8">@Model.Plate_Number</dd>

                            <dt class="col-sm-3">Violations:</dt>
                            <dd class="col-sm-9">@Model.Violations</dd>

                            <dt class="col-sm-4">Location</dt>
                            <dd class="col-sm-8">@Model.Violation_Place</dd>

                            <dt class="col-sm-4">Issued On</dt>
                            <dd class="col-sm-8">@Model.Ticket_Time.ToString("f")</dd>

                            <dt class="col-sm-4">Due Date</dt>
                            <dd class="col-sm-8">@Model.Due_Date.ToShortDateString()</dd>

                            <dt class="col-sm-4">Issued By</dt>
                            <dd class="col-sm-8">@Model.IssuedBy</dd>
                        </dl>

                        <div class="ticket-qr-section">
                            <div>
                                <img src="@qrDataUri" alt="Ticket QR" class="ticket-qr-image" />
                            </div>
                            <div class="ticket-qr-meta">
                                <p class="mb-1 fw-bold">Scan to open ticket</p>
                                <small class="text-muted">Opens: @ticketUrl</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Driver Information -->
            <div class="col-lg-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-user me-2"></i> Driver Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row driver-details-list">
                            <dt class="col-sm-4">Full Name</dt>
                            <dd class="col-sm-8">@Model.Users?.Name</dd>

                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">@Model.Email</dd>

                            <dt class="col-sm-4">License Status</dt>
                            <dd class="col-sm-8">
                                <span class="badge @GetLicenseBadgeClass(Model.Users?.License_Status)">
                                    @Model.Users?.License_Status
                                </span>
                            </dd>

                            <dt class="col-sm-4">Address</dt>
                            <dd class="col-sm-8">@Model.Users?.Address</dd>

                            <dt class="col-sm-4">Blood Type</dt>
                            <dd class="col-sm-8">@Model.Users?.Blood_Type</dd>

                            <dt class="col-sm-4">Date of Birth</dt>
                            <dd class="col-sm-8">@Model.Users?.Birth_Date.ToShortDateString()</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <!-- Full Width Row - Additional Notes -->
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-edit me-2"></i> Officer Notes</h5>
                    </div>
                    <div class="card-body">
                        @if (string.IsNullOrWhiteSpace(Model.Notes))
                        {
                            <p class="text-muted">No additional notes recorded</p>
                        }
                        else
                        {
                            <p>@Model.Notes</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.VoiceReportPath))
                        {
                            <div class="mt-3">
                                <label class="form-label">Officer Voice Report</label>
                                <audio src="@Model.VoiceReportPath" controls class="w-100"></audio>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="ticket-page-actions">
            <a asp-action="Receipt" asp-route-id="@Model.Ticket_Id" target="_blank" rel="noopener"
               class="btn btn-outline-dark">
                <i class="fas fa-print me-1"></i> Print Receipt (Signature)
            </a>
            <a asp-action="SearchTickets" asp-route-plateNumber="@Model.Plate_Number"
               class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i> All ticketsfor P_N
            </a>
        </div>
    </div>


@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Paid" => "bg-success",
            "Pending" => "bg-warning",
            "UnderProcess" => "bg-info text-white",
            _ => "bg-secondary"
        };
    }

    string GetLicenseBadgeClass(string status)
    {
        return status switch
        {
            "Valid" => "bg-success",
            "Expired" => "bg-warning",
            "Suspended" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}