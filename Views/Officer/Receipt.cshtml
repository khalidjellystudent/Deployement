@model TicketSystem.Models.Ticket
@inject TicketSystem.Services.IQrCodeService QrService
@{
    ViewData["Title"] = $"Receipt #{Model.Ticket_Id}";
    Layout = null; // print-only page

    var ticketUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Ticket/Open/{Model.Ticket_Id}";
    var qrDataUri = QrService.GeneratePngDataUri(ticketUrl, 8);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <style>
        /* 80mm receipt-friendly layout */
        :root { --receipt-width: 80mm; }
        html, body { margin: 0; padding: 0; }
        body {
            font-family: Arial, sans-serif;
            color: #111;
            background: #fff;
        }

        .receipt {
            width: var(--receipt-width);
            padding: 10px;
            margin: 0 auto;
            box-sizing: border-box;
        }

        .center { text-align: center; }
        .muted { color: #555; }
        .hr { border-top: 1px dashed #999; margin: 8px 0; }

        .row {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            font-size: 12px;
        }

        .label { font-weight: 700; }

        .qr {
            display: block;
            margin: 8px auto;
            width: 140px;
            height: 140px;
        }

        .signature {
            margin-top: 12px;
            font-size: 12px;
        }

        .sig-line {
            margin-top: 18px;
            border-top: 1px solid #000;
            height: 1px;
        }

        .sig-caption {
            margin-top: 4px;
            display: flex;
            justify-content: space-between;
            gap: 10px;
            font-size: 11px;
        }

        .print-actions {
            width: var(--receipt-width);
            margin: 10px auto;
            display: flex;
            gap: 8px;
            justify-content: center;
        }

        @@media print {
            .print-actions { display: none !important; }
            .receipt { margin: 0; }
        }
    </style>
</head>
<body>
    <div class="print-actions">
        <button onclick="window.print()">Print</button>
        <button onclick="window.close()">Close</button>
    </div>

    <div class="receipt">
        <div class="center">
            <div style="font-weight:800; font-size:14px;">Traffic Ticket Receipt</div>
            <div class="muted" style="font-size:12px;">Ticket #@Model.Ticket_Id</div>
        </div>

        <div class="hr"></div>

        <div class="row"><span class="label">Plate</span><span>@Model.Plate_Number</span></div>
        <div class="row"><span class="label">Violation</span><span style="text-align:right; max-width:55mm;">@Model.Violations</span></div>
        <div class="row"><span class="label">Location</span><span style="text-align:right; max-width:55mm;">@Model.Violation_Place</span></div>
        <div class="row"><span class="label">Issued</span><span>@Model.Ticket_Time.ToString("g")</span></div>
        <div class="row"><span class="label">Due</span><span>@Model.Due_Date.ToString("d")</span></div>
        <div class="row"><span class="label">Officer</span><span style="text-align:right; max-width:55mm;">@Model.IssuedBy</span></div>

        <div class="hr"></div>

        <div class="center" style="font-size:12px; font-weight:700;">Scan to view ticket</div>
        <img class="qr" src="@qrDataUri" alt="Ticket QR" />
        <div class="center muted" style="font-size:10px; word-break:break-all;">@ticketUrl</div>

        <div class="hr"></div>

        <div class="signature">
            <div style="font-weight:700;">Driver Acknowledgement</div>
            <div class="muted" style="margin-top:4px; line-height:1.3;">
                I acknowledge receipt of this ticket and understand that signing does not mean admission of guilt.
            </div>

            <div class="sig-line"></div>
            <div class="sig-caption">
                <span>Driver Signature</span>
                <span>Date: ____/____/______</span>
            </div>

            <div class="sig-line"></div>
            <div class="sig-caption">
                <span>Driver Name</span>
                <span>ID/Phone</span>
            </div>
        </div>

        <div class="hr"></div>
        <div class="center muted" style="font-size:10px;">
            Keep this receipt for your records.
        </div>
    </div>

    <script>
        // Optional: uncomment to auto-open print dialog
        // window.addEventListener('load', () => setTimeout(() => window.print(), 250));
    </script>
</body>
</html>
