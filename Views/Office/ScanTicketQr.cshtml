@{
    ViewData["Title"] = "Scan Ticket QR";
    Layout = "_OfficeLayout";
}

<div class="container mt-4" style="max-width: 980px;">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h3 class="mb-0">
            <i class="fas fa-qrcode me-2"></i> Scan Ticket QR
        </h3>
        <button id="btnStart" class="btn btn-primary">
            <i class="fas fa-camera me-2"></i> Start Camera
        </button>
    </div>

    <div class="alert alert-info" id="hintBox">
        This page will ask for camera permission to scan the ticket QR code.
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div id="qr-reader" style="width: 100%;"></div>
                    <div class="mt-3 d-flex gap-2">
                        <button id="btnStop" class="btn btn-outline-secondary" disabled>
                            <i class="fas fa-stop me-2"></i> Stop
                        </button>
                        <span class="text-muted" id="statusText">Idle</span>
                    </div>

                    <div class="mt-3">
                        <div class="small text-muted">
                            Security: this scanner only allows redirects to this site.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    Result
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <div class="fw-bold">Decoded value</div>
                        <div class="form-control" style="min-height: 42px;" id="decodedValue"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Paste QR text (fallback)</label>
                        <input id="manualInput" class="form-control" placeholder="/Ticket/Open/123 or full URL" />
                    </div>

                    <div class="d-flex gap-2">
                        <button id="btnGo" class="btn btn-success">
                            <i class="fas fa-arrow-right me-2"></i> Open Ticket
                        </button>
                        <button id="btnClear" class="btn btn-outline-danger">
                            Clear
                        </button>
                    </div>

                    <div class="mt-3">
                        <div class="alert alert-warning d-none" id="warningBox"></div>
                        <div class="alert alert-success d-none" id="successBox"></div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <div class="fw-bold mb-1">Expected QR format</div>
                    <div class="text-muted small">
                        Generated tickets use <code>/Ticket/Open/&lt;TicketId&gt;</code>.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- html5-qrcode (MIT) via CDN -->
    <script src="https://unpkg.com/html5-qrcode"></script>

    <script>
        (function () {
            const btnStart = document.getElementById('btnStart');
            const btnStop = document.getElementById('btnStop');
            const btnGo = document.getElementById('btnGo');
            const btnClear = document.getElementById('btnClear');
            const decodedValueEl = document.getElementById('decodedValue');
            const manualInput = document.getElementById('manualInput');
            const statusText = document.getElementById('statusText');
            const warningBox = document.getElementById('warningBox');
            const successBox = document.getElementById('successBox');

            let html5QrCode = null;
            let lastDecoded = '';

            function showWarning(msg) {
                warningBox.textContent = msg;
                warningBox.classList.remove('d-none');
                successBox.classList.add('d-none');
            }

            function showSuccess(msg) {
                successBox.textContent = msg;
                successBox.classList.remove('d-none');
                warningBox.classList.add('d-none');
            }

            function clearMessages() {
                warningBox.classList.add('d-none');
                successBox.classList.add('d-none');
            }

            function setDecoded(value) {
                lastDecoded = value || '';
                decodedValueEl.textContent = lastDecoded;
                if (lastDecoded) {
                    manualInput.value = lastDecoded;
                }
            }

            function normalizeToSafeLocalUrl(input) {
                const raw = (input || '').trim();
                if (!raw) return null;

                // Allow scanning just the ticket id.
                if (/^\d+$/.test(raw)) {
                    return `/Ticket/Open/${raw}`;
                }

                // If it's a relative path (starts with /), accept it.
                if (raw.startsWith('/')) {
                    return raw;
                }

                // If it's an absolute URL, only accept same-origin.
                try {
                    const u = new URL(raw);
                    if (u.origin !== window.location.origin) {
                        return null;
                    }
                    return u.pathname + u.search + u.hash;
                } catch {
                    return null;
                }
            }

            function openTicketFromInput(value) {
                clearMessages();

                const safePath = normalizeToSafeLocalUrl(value);
                if (!safePath) {
                    showWarning('Blocked: QR code is not a valid link for this site.');
                    return;
                }

                // Strong preference: only allow the known entry route.
                if (!safePath.toLowerCase().startsWith('/ticket/open')) {
                    showWarning('Blocked: only /Ticket/Open/* links are allowed.');
                    return;
                }

                showSuccess('Opening ticket…');
                window.location.href = safePath;
            }

            function isSecureForCamera() {
                // getUserMedia requires a secure context (HTTPS) except for localhost.
                // window.isSecureContext already accounts for localhost in modern browsers.
                return !!window.isSecureContext;
            }

            function formatCameraError(err) {
                if (!err) return 'Unknown camera error.';
                const name = err.name || '';
                const message = err.message || err.toString();
                // Common cases: NotAllowedError, NotFoundError, NotReadableError, OverconstrainedError, SecurityError
                return name ? `${name}: ${message}` : message;
            }

            btnGo.addEventListener('click', function () {
                openTicketFromInput(manualInput.value);
            });

            btnClear.addEventListener('click', function () {
                setDecoded('');
                manualInput.value = '';
                clearMessages();
            });

            btnStart.addEventListener('click', async function () {
                clearMessages();

                if (!window.Html5Qrcode) {
                    showWarning('QR scanner library failed to load. Check internet access.');
                    return;
                }

                // Check secure context first. On HTTP (especially LAN/IP access), some browsers expose no getUserMedia at all.
                if (!isSecureForCamera()) {
                    showWarning('Camera access requires HTTPS (secure context). Open this site via https:// or run using the HTTPS profile.');
                    statusText.textContent = 'Blocked (not HTTPS)';
                    return;
                }

                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    showWarning('This browser does not support camera access (getUserMedia). Try Chrome/Edge/Safari (latest) and avoid in-app browsers.');
                    return;
                }

                if (!html5QrCode) {
                    html5QrCode = new Html5Qrcode('qr-reader');
                }

                btnStart.disabled = true;
                btnStop.disabled = false;
                statusText.textContent = 'Requesting camera permission…';

                try {
                    // Important: do NOT call getCameras() first.
                    // Many browsers won’t enumerate cameras/labels until permission is granted.
                    // Starting with facingMode triggers the permission prompt reliably.
                    const config = { fps: 10, qrbox: { width: 250, height: 250 } };
                    const onScanSuccess = function (decodedText) {
                        if (!decodedText || decodedText === lastDecoded) return;
                        setDecoded(decodedText);
                        statusText.textContent = 'QR detected';
                        openTicketFromInput(decodedText);
                    };
                    const onScanFailure = function (_) { };

                    try {
                        await html5QrCode.start(
                            { facingMode: { ideal: 'environment' } },
                            config,
                            onScanSuccess,
                            onScanFailure
                        );
                    } catch (primaryErr) {
                        // Fallback: if facingMode constraint fails, try explicit deviceId.
                        const cameras = await Html5Qrcode.getCameras();
                        if (!cameras || cameras.length === 0) {
                            throw primaryErr;
                        }

                        const preferred = cameras.find(c => /back|rear|environment/i.test(c.label)) || cameras[0];
                        await html5QrCode.start(
                            { deviceId: { exact: preferred.id } },
                            config,
                            onScanSuccess,
                            onScanFailure
                        );
                    }

                    statusText.textContent = 'Scanning…';
                } catch (err) {
                    console.error(err);
                    showWarning('Camera failed to start. ' + formatCameraError(err));
                    statusText.textContent = 'Stopped / blocked';
                    btnStart.disabled = false;
                    btnStop.disabled = true;
                }
            });

            btnStop.addEventListener('click', async function () {
                clearMessages();
                if (!html5QrCode) return;

                try {
                    await html5QrCode.stop();
                    await html5QrCode.clear();
                } catch (err) {
                    // ignore
                }

                statusText.textContent = 'Stopped';
                btnStart.disabled = false;
                btnStop.disabled = true;
            });
        })();
    </script>
}
