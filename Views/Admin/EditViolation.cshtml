@model TicketSystem.Models.Violation
@{
    ViewData["Title"] = "تعديل المخالفة";
    Layout = "_AdminLayout";
}

@section Styles {
    <style>
        .toggle-track { transition: background-color 0.15s ease; }
        .toggle-knob { transition: transform 0.15s ease; }
        .ts-toggle input:checked + .toggle-track { background-color: #2563eb; }
        .ts-toggle input:checked + .toggle-track .toggle-knob { transform: translateX(18px); }
    </style>
}

<div class="max-w-2xl">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">تعديل مخالفة</h1>
            <p class="text-sm text-gray-500">تعديل الاسم وقيمة الغرامة</p>
        </div>
        <a asp-controller="Admin" asp-action="ViolationList" class="text-blue-700 hover:text-blue-800">العودة</a>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-6">
        <form asp-controller="Admin" asp-action="EditViolation" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div>
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">اسم المخالفة</label>
                <input asp-for="Name" class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
                <span asp-validation-for="Name" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Cost" class="block text-sm font-medium text-gray-700 mb-1">قيمة الغرامة</label>
                <input asp-for="Cost" type="number" step="0.01" min="0" class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-200" />
                <span asp-validation-for="Cost" class="text-sm text-red-600"></span>
            </div>

            <div class="flex items-center gap-2">
                <label class="ts-toggle inline-flex items-center cursor-pointer select-none">
                    <input asp-for="IsActive" type="checkbox" class="sr-only" />
                    <div class="toggle-track relative w-10 h-6 rounded-full bg-gray-200">
                        <div class="toggle-knob absolute top-0.5 left-0.5 h-5 w-5 rounded-full bg-white shadow"></div>
                    </div>
                    <span class="mr-3 text-sm text-gray-700">نشطة</span>
                </label>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit" class="px-5 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700">حفظ</button>
                <a asp-controller="Admin" asp-action="ViolationList" class="px-5 py-2 rounded-lg bg-gray-100 text-gray-800 hover:bg-gray-200">إلغاء</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
