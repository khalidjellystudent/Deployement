@model IEnumerable<TicketSystem.Models.Violation>
@{
    ViewData["Title"] = "إدارة المخالفات";
    Layout = "_AdminLayout";
}

@section Styles {
    <style>
        .toggle-track { transition: background-color 0.15s ease; }
        .toggle-knob { transition: transform 0.15s ease; }
        .ts-toggle input:checked + .toggle-track { background-color: #2563eb; }
        .ts-toggle input:checked + .toggle-track .toggle-knob { transform: translateX(18px); }
    </style>
}

<div class="max-w-5xl">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">إدارة المخالفات</h1>
            <p class="text-sm text-gray-500">إضافة / تعديل / تفعيل / حذف المخالفات</p>
        </div>
        <a asp-controller="Admin" asp-action="AddViolation" class="inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700">
            إضافة مخالفة
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-4 rounded-lg border border-blue-100 bg-blue-50 px-4 py-3 text-blue-800">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">الاسم</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">الغرامة</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">الحالة</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">إجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 bg-white">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-8 text-center text-gray-500">لا توجد مخالفات. قم بإضافة مخالفة جديدة.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var v in Model)
                        {
                            <tr class="hover:bg-gray-50 cursor-pointer" data-edit-url="@Url.Action("EditViolation", "Admin", new { id = v.Id })">
                                <td class="px-6 py-4 text-gray-900 font-medium">@v.Name</td>
                                <td class="px-6 py-4 text-gray-700">@v.Cost.ToString("N2")</td>
                                <td class="px-6 py-4">
                                    @if (v.IsActive)
                                    {
                                        <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-1 text-xs text-blue-700">نشطة</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-1 text-xs text-gray-700">غير نشطة</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-left">
                                    <div class="inline-flex items-center gap-2">
                                        <form asp-controller="Admin" asp-action="ToggleViolationActive" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@v.Id" />
                                            <label class="ts-toggle inline-flex items-center cursor-pointer select-none" title="@(v.IsActive ? "تعطيل" : "تفعيل")">
                                                <input type="checkbox" class="sr-only" @(v.IsActive ? "checked" : null) onchange="this.form.submit()" />
                                                <div class="toggle-track relative w-10 h-6 rounded-full bg-gray-200">
                                                    <div class="toggle-knob absolute top-0.5 left-0.5 h-5 w-5 rounded-full bg-white shadow"></div>
                                                </div>
                                            </label>
                                        </form>

                                        <form asp-controller="Admin" asp-action="DeleteViolation" method="post" class="inline" onsubmit="return confirm('حذف هذه المخالفة؟');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@v.Id" />
                                            <button type="submit" class="px-3 py-1.5 rounded-lg bg-gray-100 text-gray-800 hover:bg-gray-200">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('tr[data-edit-url]').forEach(row => {
                row.addEventListener('click', function (e) {
                    if (e.target.closest('form, button, input, label, a')) return;
                    const url = row.getAttribute('data-edit-url');
                    if (url) window.location.href = url;
                });
            });
        });
    </script>
}
