@{
    ViewData["Title"] = "الرئيسية | نظام المخالفات المرورية";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        :root {
            --official-white: #ffffff;
            --official-gray-100: #f3f4f6;
            --official-gray-500: #6b7280;
            --official-gray-900: #1f2937;
            --official-brown-300: #cbb79d;
        }

        .home-official {
            background: linear-gradient(180deg, var(--official-white) 0%, var(--official-gray-100) 100%);
            min-height: calc(100vh - 200px);
        }

        .home-wrap {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .section-shell {
            background: var(--official-white);
            border: 1px solid #e5e7eb;
            border-radius: 1rem;
            box-shadow: 0 14px 28px rgba(31, 41, 55, 0.08), 0 3px 8px rgba(31, 41, 55, 0.06);
            padding: 1.75rem;
        }

        .home-hero {
            padding: 4rem 0 2.75rem;
            margin-top: 1.2rem;
        }

        .home-badge {
            display: inline-block;
            background: #f7f3ee;
            border: 1px solid #eadfce;
            color: var(--official-gray-900);
            font-size: 0.85rem;
            font-weight: 700;
            padding: 0.4rem 0.8rem;
            border-radius: 999px;
        }

        .home-title {
            margin: 1rem 0 0.9rem;
            color: var(--official-gray-900);
            font-size: clamp(2rem, 4vw, 3rem);
            line-height: 1.25;
            font-weight: 900;
        }

        .home-text {
            color: var(--official-gray-500);
            line-height: 1.9;
            max-width: 65ch;
        }

        .home-actions {
            margin-top: 1.5rem;
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .btn-main,
        .btn-alt {
            border-radius: 0.75rem;
            padding: 0.75rem 1.25rem;
            font-weight: 700;
            transition: all 0.2s ease;
        }

        .btn-main {
            background: var(--official-gray-900);
            color: var(--official-white);
        }

        .btn-main:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(31, 41, 55, 0.15);
        }

        .btn-alt {
            background: var(--official-white);
            color: var(--official-gray-900);
            border: 1px solid #d1d5db;
        }

        .btn-alt:hover {
            border-color: var(--official-brown-300);
            background: #faf8f5;
        }

        .home-section {
            padding: 2.25rem 0;
        }

        .section-title {
            color: var(--official-gray-900);
            font-size: 1.35rem;
            font-weight: 800;
            margin-bottom: 0.4rem;
        }

        .section-sub {
            color: var(--official-gray-500);
            margin-bottom: 1rem;
        }

        .service-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1rem;
        }

        .service-card {
            background: var(--official-white);
            border: 1px solid #e5e7eb;
            border-radius: 0.9rem;
            padding: 1rem;
        }

        .service-card h3 {
            margin: 0 0 0.4rem;
            color: var(--official-gray-900);
            font-size: 1.05rem;
            font-weight: 800;
        }

        .service-card p {
            margin: 0;
            color: var(--official-gray-500);
            line-height: 1.75;
            font-size: 0.95rem;
        }

        .status-box {
            margin-top: 1.25rem;
            background: #faf8f5;
            border-right: 4px solid var(--official-brown-300);
            border-radius: 0.75rem;
            padding: 0.85rem 1rem;
            color: var(--official-gray-900);
        }

        @@media (max-width: 900px) {
            .service-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 640px) {
            .home-hero {
                padding: 3rem 0 2.25rem;
            }

            .section-shell {
                padding: 1.1rem;
            }

            .service-grid {
                grid-template-columns: 1fr;
            }

            .home-actions {
                flex-direction: column;
            }
        }
    </style>
}

<div class="home-official">
    <section class="home-hero">
        <div class="home-wrap section-shell">
            <span class="home-badge">البوابة الرسمية لخدمات المرور</span>
            <h1 class="home-title">نظام إدارة المخالفات المرورية</h1>
            <p class="home-text">
                منصة رسمية موحّدة تتيح الاستعلام عن المخالفات المرورية ومتابعة حالتها وسدادها إلكترونياً
                بطريقة واضحة وآمنة.
            </p>

            <div class="home-actions">
                <a asp-controller="Home" asp-action="Login" class="btn-main">الدخول إلى النظام</a>
                <a asp-controller="Home" asp-action="Manual" class="btn-alt">دليل الاستخدام</a>
            </div>
            <div class="status-box">
                <strong>تنويه:</strong> يرجى استخدام الحساب الشخصي الرسمي عند إجراء أي عملية دفع أو متابعة.
            </div>
        </div>
    </section>

    <section class="home-section">
        <div class="home-wrap section-shell">
            <h2 class="section-title">الخدمات الأساسية</h2>
            <p class="section-sub">الوصول السريع إلى أهم الوظائف داخل النظام.</p>

            <div class="service-grid">
                <article class="service-card">
                    <h3>الاستعلام عن المخالفات</h3>
                    <p>عرض بيانات المخالفة، تاريخها، وحالتها الحالية.</p>
                </article>

                <article class="service-card">
                    <h3>السداد الإلكتروني</h3>
                    <p>تنفيذ السداد إلكترونياً وتحديث الحالة مباشرة بعد الدفع.</p>
                </article>

                <article class="service-card">
                    <h3>لوائح المرور</h3>
                    <p>الاطلاع على القوانين واللوائح التنظيمية ذات العلاقة.</p>
                </article>
            </div>
        </div>
    </section>
</div>
