@using TicketSystem.Models
@model LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        :root {
            --official-white: #ffffff;
            --official-gray-100: #f3f4f6;
            --official-gray-500: #6b7280;
            --official-gray-900: #1f2937;
            --official-brown-300: #cbb79d;
        }

        .login-official {
            background: linear-gradient(180deg, var(--official-white) 0%, var(--official-gray-100) 100%);
            min-height: calc(100vh - 200px);
            padding: 2.5rem 1rem;
        }

        .login-wrap {
            max-width: 460px;
            margin: 0 auto;
        }

        .login-panel {
            background: var(--official-white);
            border: 1px solid #e5e7eb;
            border-radius: 1rem;
            box-shadow: 0 14px 28px rgba(31, 41, 55, 0.08), 0 3px 8px rgba(31, 41, 55, 0.06);
            padding: 1.5rem;
        }

        .login-badge {
            display: inline-block;
            background: #f7f3ee;
            border: 1px solid #eadfce;
            color: var(--official-gray-900);
            font-size: 0.8rem;
            font-weight: 700;
            padding: 0.35rem 0.75rem;
            border-radius: 999px;
            margin-bottom: 0.7rem;
        }

        .login-title {
            color: var(--official-gray-900);
            font-size: 1.9rem;
            font-weight: 900;
            margin: 0 0 0.35rem;
        }

        .login-sub {
            color: var(--official-gray-500);
            margin: 0 0 1.2rem;
            line-height: 1.7;
        }

        .field-label {
            display: block;
            color: var(--official-gray-900);
            font-size: 0.9rem;
            font-weight: 700;
            margin-bottom: 0.45rem;
        }

        .field-input {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 0.75rem;
            padding: 0.75rem 0.85rem;
            color: var(--official-gray-900);
            background: var(--official-white);
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .field-input:focus {
            outline: none;
            border-color: var(--official-brown-300);
            box-shadow: 0 0 0 3px rgba(203, 183, 157, 0.25);
        }

        .input-with-icon {
            position: relative;
        }

        .icon-right {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            pointer-events: none;
        }

        .icon-left {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
        }

        .toggle-password {
            border: 0;
            background: transparent;
            color: #6b7280;
        }

        .toggle-password:hover {
            color: var(--official-gray-900);
        }

        .input-pad-right {
            padding-right: 2.4rem;
        }

        .input-pad-left {
            padding-left: 2.4rem;
        }

        .btn-login {
            width: 100%;
            border: 0;
            border-radius: 0.75rem;
            padding: 0.8rem 1rem;
            background: var(--official-gray-900);
            color: var(--official-white);
            font-weight: 800;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(31, 41, 55, 0.15);
        }

        .alert-error {
            background: #fff5f5;
            border: 1px solid #fecaca;
            color: #991b1b;
            border-radius: 0.75rem;
            padding: 0.75rem 0.9rem;
            font-size: 0.9rem;
        }

        .notice-box {
            margin-top: 1rem;
            background: #faf8f5;
            border-right: 4px solid var(--official-brown-300);
            border-radius: 0.75rem;
            padding: 0.8rem 0.95rem;
            color: var(--official-gray-900);
            font-size: 0.88rem;
        }

        .helper-link {
            color: var(--official-gray-500);
            font-size: 0.9rem;
        }

        .helper-link a {
            color: var(--official-gray-900);
            font-weight: 700;
            text-decoration: none;
            border-bottom: 1px solid transparent;
        }

        .helper-link a:hover {
            border-bottom-color: var(--official-brown-300);
        }
    </style>
}

<section class="login-official">
    <div class="login-wrap login-panel">
        <span class="login-badge">البوابة الرسمية لخدمات المرور</span>
        <h1 class="login-title">تسجيل الدخول</h1>
        <p class="login-sub">يرجى إدخال بيانات الحساب للوصول إلى نظام المخالفات المرورية.</p>

        <form asp-action="Login" asp-controller="Home" method="post" class="space-y-4">
            <input asp-for="ReturnUrl" type="hidden" />

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
            {
                var errorMessage = ViewData.ModelState.Values.SelectMany(v => v.Errors).FirstOrDefault()?.ErrorMessage;
                if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert-error">@errorMessage</div>
                }
            }

            <div>
                <label asp-for="Email" class="field-label">البريد الإلكتروني</label>
                <div class="input-with-icon">
                    <span class="icon-right">
                        <i class="fas fa-envelope"></i>
                    </span>
                    <input asp-for="Email" class="field-input input-pad-right" placeholder="أدخل بريدك الإلكتروني" />
                </div>
                <span asp-validation-for="Email" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Password" class="field-label">كلمة المرور</label>
                <div class="input-with-icon">
                    <span class="icon-right">
                        <i class="fas fa-lock"></i>
                    </span>
                    <span class="icon-left">
                        <button id="togglePassword" type="button" class="toggle-password" aria-pressed="false" aria-label="إظهار كلمة المرور">
                            <i id="togglePasswordIcon" class="fas fa-eye"></i>
                        </button>
                    </span>
                    <input asp-for="Password" type="password" id="Password" class="field-input input-pad-right input-pad-left" placeholder="أدخل كلمة المرور" />
                </div>
                <span asp-validation-for="Password" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div class="flex items-center">
                <input asp-for="RememberMe" type="checkbox" class="h-4 w-4 border-gray-300 rounded" />
                <label asp-for="RememberMe" class="mr-2 block text-sm text-gray-700">تذكرني</label>
            </div>

            <button type="submit" class="btn-login">تسجيل الدخول</button>

            <div class="text-center helper-link">
                <a href="#">نسيت كلمة المرور؟</a>
                <div class="mt-2">ليس لديك حساب؟ <a href="#">تواصل مع الإدارة</a></div>
            </div>
        </form>

        <div class="notice-box mt-4">
            <strong>تنويه أمني:</strong> جميع البيانات المرسلة عبر هذه الصفحة تتم معالجتها ضمن بيئة آمنة.
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('togglePassword');
            const pwdInput = document.getElementById('Password');
            const icon = document.getElementById('togglePasswordIcon');

            if (toggleBtn && pwdInput && icon) {
                toggleBtn.addEventListener('click', function () {
                    const isHidden = pwdInput.type === 'password';
                    pwdInput.type = isHidden ? 'text' : 'password';
                    toggleBtn.setAttribute('aria-pressed', String(isHidden));
                    toggleBtn.setAttribute('aria-label', isHidden ? 'إخفاء كلمة المرور' : 'إظهار كلمة المرور');
                    icon.classList.toggle('fa-eye');
                    icon.classList.toggle('fa-eye-slash');
                });
            }
        });
    </script>
}



